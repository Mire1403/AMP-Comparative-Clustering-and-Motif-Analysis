############################
# OS / Editor
############################
.DS_Store
Thumbs.db
.vscode/
.idea/

############################
# Python
############################
__pycache__/
*.pyc
.ipynb_checkpoints/

############################
# Data (raw often large/licensed)
############################
data/raw/**
data/intermediate/*.csv
data/intermediate/nonamp_clean_min5.fasta
############################
# Heavy results / tool outputs
# (keep statistics summaries/plots tracked if you want)
############################
results/clustering/**
results/motif_scanning/**
results/motif_discovery/**

# Tomtom can be large; if you plan to upload only summary later, ignore:
results/motif_similarity/**

# Background FASTAs can be large
results/background_generation/**/*.fasta

############################
# MMseqs2 temp databases
############################
**/mmseq_tmp*/
**/tmp*/
*.db
*.dbtype
*.index
*.lookup
*.source
*.clu*

# Reproducible FASTA intermediates
results/clustering/AMP_MASTER.fasta
results/clustering/AMP_MASTER_mmseq_all_seqs.fasta

# Non-AMP clustering outputs
results/clustering/NONAMP_*

# ignore heavy pipeline outputs
results/background_generation/
results/clustering/
results/motif_discovery/
results/motif_scanning/

# keep statistics
!results/statistics/

# ignore temp files
*.tmp
*.log
mmseq_tmp*

############################
# MEME Suite verbose reports
############################
*.eps
sites.tsv
sequences.tsv
*.xml

# Manifest files
*manifest.txt

############################
# Logs
############################
*.log

# --- Allow lightweight motif discovery outputs (track these) ---
!results/motif_discovery/
!results/motif_discovery/**/
!results/motif_discovery/**/meme.html
!results/motif_discovery/**/meme.txt
!results/motif_discovery/**/streme.html
!results/motif_discovery/**/streme.txt
